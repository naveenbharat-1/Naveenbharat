<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Edge-to-edge: let app content extend into the display cutout (notch) area
         on Android 9+ devices. Combined with viewport-fit=cover + env(safe-area-inset-*)
         in CSS, this gives correct edge-to-edge layout on notched phones. -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
